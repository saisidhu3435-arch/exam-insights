{
  "buildCommand": "pnpm install && pnpm build",
  "outputDirectory": "artifacts/minute-ahead/dist/public",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}